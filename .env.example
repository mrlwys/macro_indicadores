# Shared (docker-compose)
NODE_ENV=development
API_PORT=4000
CORS_ORIGIN=http://localhost:5173

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
SYNC_SECRET=
SYNC_LOCK_TTL_MINUTES=30
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# Web
VITE_API_BASE_URL=/api
VITE_PROXY_TARGET=http://localhost:4000

# Nomus ERP (preencher antes de ativar a integração)
NOMUS_SYNC_ENABLED=false
NOMUS_BASE_URL=https://empresa.nomus.com.br/empresa/rest
NOMUS_INTEGRATION_KEY=
NOMUS_TIMEOUT_MS=30000
NOMUS_MAX_RETRIES=5
NOMUS_BACKOFF_BASE_MS=1000
NOMUS_BACKOFF_MAX_MS=30000
NOMUS_THROTTLE_MAX_WAIT_MS=180000
NOMUS_SYNC_INTERVAL_MINUTES=10
NOMUS_INITIAL_BACKFILL_DAYS=365
NOMUS_INCREMENTAL_LOOKBACK_DAYS=7
NOMUS_INCREMENTAL_LOOKBACK_PAGES=3
NOMUS_PAGE_START=1
NOMUS_MAX_PAGES_PER_RUN=200
NOMUS_ENABLED_ENDPOINTS=propostas,pedidos,contasReceber,processos,ordens
